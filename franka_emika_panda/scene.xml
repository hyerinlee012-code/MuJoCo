<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20" offwidth="640" offheight="640"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0.1 0.2 0.3" width="512" height="512"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"/>
    
    <material name="mat_glass" rgba="0.9 0.9 1.0 0.3" specular="1.0" shininess="1.0" reflectance="0.8" emission="0.05" roughness="0.0"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    
    <camera name="material_cam" pos="0.8 0 0.4" xyaxes="0 -1 0 0.5 0 1"/>

    <body name="cup_glass" pos="0.5 0 0.05">
      <freejoint/>
      <geom name="glass_bottom" type="cylinder" size="0.03 0.005" material="mat_glass"/>
      <geom name="glass_wall1" type="box" size="0.03 0.002 0.05" pos="0 0.03 0.05" material="mat_glass"/>
      <geom name="glass_wall2" type="box" size="0.03 0.002 0.05" pos="0 -0.03 0.05" material="mat_glass"/>
      <geom name="glass_wall3" type="box" size="0.002 0.03 0.05" pos="0.03 0 0.05" material="mat_glass"/>
      <geom name="glass_wall4" type="box" size="0.002 0.03 0.05" pos="-0.03 0 0.05" material="mat_glass"/>
    </body>
 </worldbody>
</mujoco>
